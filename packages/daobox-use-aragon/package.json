    "@types/mocha": "^10.0.1",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "eslint": "^7.32.0",
    "eslint-config-daobox": "workspace:*",
    "jest": "^29.6.2",
    "jest-environment-jsdom": "^29.6.2",
    "mocha": "^10.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "size-limit": "^8.2.6",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tslib": "^2.6.1",
    "tsup": "^5.12.9",
    "typescript": "^4.9.5"
