{
  "name": "@daobox/use-aragon",
  "version": "0.0.3-beta-12",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --external react",
    "dev": "tsup src/index.tsx --format esm --watch --dts --external react",
    "lint": "eslint \"src/**/*.ts*\"",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "test": "jest",
    "watch": "jest --watch"
  },
  "dependencies": {
    "@aragon/osx-ethers": "^1.2.1",
    "@aragon/sdk-client": "^1.3.1",
    "@testing-library/react-hooks": "^8.0.1",
    "ethers": "^5.7.2",
    "react-query": "^3.39.3",
    "wagmi": "~0.11.7",
    "zod": "^3.21.4"
  },
  "peerDependencies": {
    "wagmi": "~0.11.7"
  },
  "devDependencies": {
    "@daobox/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/mocha": "^10.0.1",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "eslint": "^7.32.0",
    "eslint-config-daobox": "workspace:*",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "mocha": "^10.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "size-limit": "^8.2.4",
    "ts-jest": "^29.0.5",
    "tslib": "^2.5.0",
    "tsup": "^5.10.1",
    "typescript": "^4.9.5"
  },
  "publishConfig": {
    "access": "public"
  }
