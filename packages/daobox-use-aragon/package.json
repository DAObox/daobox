    "@testing-library/react-hooks": "^8.0.1",
    "ethers": "^5.7.2",
    "graphql": "^16.8.0",
    "graphql-request": "^5.2.0",
    "wagmi": "~0.11.7",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "wagmi": "~0.11.7"
  },
  "devDependencies": {
    "@daobox/tsconfig": "workspace:*",
    "@graphql-codegen/cli": "^3.3.1",
    "@graphql-codegen/client-preset": "^3.0.1",
    "@testing-library/jest-dom": "^5.17.0",
